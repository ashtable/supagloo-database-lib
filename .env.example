# @supagloo/database-lib — local env for the Prisma CLI (migrate / validate).
#
# Copy to `.env` for local use (optional): `cp .env.example .env`.
# prisma.config.ts loads this file if present; an already-set DATABASE_URL in
# the environment takes precedence.
#
# Default points at the root Docker Compose Postgres (app database `supagloo`).
# Start it with: `docker compose up -d postgres` from /Users/ash/code/supagloo.
DATABASE_URL=postgres://supagloo:supagloo@localhost:5432/supagloo

# Application-level secrets encryption key (design-delta §2.10) — used by
# encryptSecret/decryptSecret to protect the OpenRouter key and Gloo client
# secret at rest (AES-256-GCM). MUST be a 64-character hex string = 32 bytes,
# DISTINCT per environment. Generate with: `openssl rand -hex 32`.
# The value below is a well-known dev-only placeholder — never use it in prod.
SECRETS_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
